# Server Configuration
PORT=3000
NODE_ENV=production

# TikTok Shop App Configuration
TIKTOK_APP_KEY=your_app_key_here
TIKTOK_APP_SECRET=your_app_secret_here

# Webhook Configuration
WEBHOOK_PATH=/api/webhooks/tiktok
