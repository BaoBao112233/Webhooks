# Server Configuration
PORT=3001
NODE_ENV=production

# Facebook App Configuration
# Lấy từ https://developers.facebook.com/apps → App Settings → Basic
FB_APP_ID=your_app_id_here
FB_APP_SECRET=your_app_secret_here

# Webhook verify token - do bạn tự đặt, điền trùng khi cấu hình webhook trên FB
FB_VERIFY_TOKEN=your_verify_token_here

# Page Access Token (dùng khi gọi lại Graph API để gửi tin nhắn)
PAGE_ACCESS_TOKEN=your_page_access_token_here

# Tag để phân loại tin nhắn echo: gọi Send API kèm metadata=ai để đánh dấu là AI
# Echo có app_id=FB_APP_ID được tự động coi là AI; còn lại coi là Staff (Page Inbox)
AI_METADATA_TAG=ai

# Chatbot API (Lubylab Chatbot - Gemini)
CHATBOT_API_URL=http://localhost:5555
CHATBOT_LIMIT_WORDS=500
CHATBOT_SOCIAL_NETWORK=messenger
# Bật/tắt auto-reply toàn cục (master switch). Khi staff trả lời cho 1 user thì
# AI chỉ tắt với riêng user đó (per-user handover), KHÔNG ảnh hưởng cờ này.
AUTO_REPLY_ENABLED=true

# Cửa sổ gom tin nhắn user (ms) — các tin nhắn liên tiếp trong cửa sổ này sẽ được nối lại
# rồi mới gọi chatbot 1 lần
BATCH_WINDOW_MS=3000

# Khoảng nghỉ giữa các đoạn khi reply bị tách theo "\n\n" (ms). 0 = gửi liên tiếp
MESSAGE_CHUNK_DELAY_MS=600

# Graph API version dùng để gọi Send API
GRAPH_API_VERSION=v19.0

# Webhook Paths
WEBHOOK_PATH=/api/webhooks/fb
MESSENGER_WEBHOOK_PATH=/api/webhooks/messenger

# Domain Configuration (for production)
DOMAIN=yourdomain.com
